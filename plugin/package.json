{
  "name": "figma-mcp-go-plugin",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"vite build --watch -c vite.config.main.ts\" \"node scripts/sync-build.mjs --watch\"",
